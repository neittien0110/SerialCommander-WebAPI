# Firebase Admin — JSON kịch bản lưu Firestore; Storage bucket khởi tạo sẵn cho tương lai (ảnh, firmware)
# Đường dẫn tương đối tính từ thư mục chạy server (thường là SerialCommander-WebAPI-main)
FIREBASE_SERVICE_ACCOUNT_PATH=firebase_mgnt/serviceAccountKey.json
# FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
# FIREBASE_SCENARIOS_COLLECTION=scenarios
# Tiền tố file đính kèm (API /api/firebase/storage/*) — mỗi user: {prefix}/users/{userId}/
# FIREBASE_STORAGE_ATTACHMENTS_PREFIX=attachments
# Snapshot JSON kịch bản song song Firestore: {prefix}/{scenarioId}.json
# FIREBASE_STORAGE_SCENARIO_JSON_PREFIX=scenario-json
# FIREBASE_STORAGE_MAX_MB=5
